# Copy this file to .env and fill in your values.
# The database schema is applied automatically on startup — no manual migration steps needed.

FLASK_ENV=production            # development | production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

SECRET_KEY=change-me-to-a-random-string

# Database — leave DATABASE_URL unset (or comment out) to use SQLite in the project directory.
# DATABASE_URL=sqlite:////home/youruser/Leash/leash.db

# PostgreSQL (production):
DATABASE_URL=postgresql://leash:password@localhost/leash

# BirdDog network
NDI_SUBNET_PREFIX=10.1.248.
NDI_DEVICE_PORT=8080
NDI_DEVICE_PASSWORD=birddog

# Per-device HTTP timeout in seconds
HTTP_TIMEOUT=5

# Max simultaneous BirdDog API calls during recalls and enforcement corrections.
# Tune upward for faster large-room recalls; tune downward if the switch struggles.
RECALL_CONCURRENCY=10

# How often (seconds) the enforcement poller checks active persistence windows.
ENFORCEMENT_INTERVAL=60

# Tractus MV API — single source of truth for available NDI sources.
# Comma-separated list of hosts; primary is tried first, fallback second.
TRACTUS_MV_HOSTS=10.1.248.191,10.1.248.192
TRACTUS_MV_PORT=8901

# How often (seconds) the background job syncs NDISource table from Tractus MV.
SOURCE_POLL_INTERVAL=60

# How often (seconds) the background job polls all receivers for their current source.
RECEIVER_POLL_INTERVAL=15

# External API key for /api/v1/ endpoints.
# Leave commented out (or empty) to allow unauthenticated access (trusted LAN only).
# If set, callers must send:  X-API-Key: <value>  or  ?api_key=<value>
# API_KEY=change-me-to-a-random-string
