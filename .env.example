# Copy this file to .env and fill in the three required values below.
# All other settings (BirdDog network, Tractus MV, polling intervals, etc.)
# are configured through the Settings UI at /settings and stored in the database.

# Flask runtime mode
FLASK_ENV=production            # development | production

# Required: a long random string used to sign session cookies.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# Required: database connection.
# Leave DATABASE_URL unset (or comment it out) to use SQLite in the project directory.
# DATABASE_URL=sqlite:////home/youruser/Leash/leash.db
DATABASE_URL=postgresql://leash:password@localhost/leash

# PostgreSQL schema name — Leash creates and uses this schema so its tables
# don't collide with other apps in the same shared database.  Defaults to
# 'leash'.  Has no effect when DATABASE_URL points at SQLite.
DATABASE_SCHEMA=leash

# Optional: override startup listen address and port (default 0.0.0.0:5000).
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000

# ---------------------------------------------------------------------------
# First-boot seed values (optional)
# ---------------------------------------------------------------------------
# If these are set when Leash starts for the very first time, they will be
# written into the database as the initial values for those settings.
# After that the database takes over — changing these env vars has no effect.
# It is safe to remove them from .env once the database has been seeded.
#
# NDI_SUBNET_PREFIX=10.1.248.
# NDI_DEVICE_PORT=8080
# NDI_DEVICE_PASSWORD=birddog
# TRACTUS_MV_HOSTS=10.1.248.191,10.1.248.192
# TRACTUS_MV_PORT=8901
